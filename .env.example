# ==============================================================================
# 3M QR Studio - Environment Variables Template
# Copy this file to .env and configure the variables accordingly.
# ==============================================================================

PORT=5000
NODE_ENV=development
API_URL=http://localhost:5000
FRONTEND_URL=http://localhost:3000

# ------------------------------------------------------------------------------
# Database Settings (PostgreSQL)
# ------------------------------------------------------------------------------
DATABASE_URL="postgresql://postgres:postgres_password@localhost:5432/qr_studio?schema=public"

# ------------------------------------------------------------------------------
# Cache & Queues (Redis)
# ------------------------------------------------------------------------------
REDIS_URL="redis://localhost:6379"
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ------------------------------------------------------------------------------
# Authentication (JWT & Cookies)
# ------------------------------------------------------------------------------
JWT_ACCESS_SECRET="super-secret-access-token-key-change-in-production"
JWT_REFRESH_SECRET="super-secret-refresh-token-key-change-in-production"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# ------------------------------------------------------------------------------
# OAuth Configurations
# ------------------------------------------------------------------------------
# Google OAuth
GOOGLE_CLIENT_ID="google-client-id-placeholder"
GOOGLE_CLIENT_SECRET="google-client-secret-placeholder"
GOOGLE_CALLBACK_URL="http://localhost:5000/api/auth/google/callback"

# GitHub OAuth
GITHUB_CLIENT_ID="github-client-id-placeholder"
GITHUB_CLIENT_SECRET="github-client-secret-placeholder"
GITHUB_CALLBACK_URL="http://localhost:5000/api/auth/github/callback"

# Discord OAuth
DISCORD_CLIENT_ID="discord-client-id-placeholder"
DISCORD_CLIENT_SECRET="discord-client-secret-placeholder"
DISCORD_CALLBACK_URL="http://localhost:5000/api/auth/discord/callback"

# ------------------------------------------------------------------------------
# Storage Configurations (Supabase Storage / Cloudinary)
# ------------------------------------------------------------------------------
STORAGE_PROVIDER="cloudinary" # "cloudinary" or "supabase"

# Cloudinary Config (if provider is cloudinary)
CLOUDINARY_CLOUD_NAME="cloudinary-cloud-name-placeholder"
CLOUDINARY_API_KEY="cloudinary-api-key-placeholder"
CLOUDINARY_API_SECRET="cloudinary-api-secret-placeholder"

# Supabase Storage Config (if provider is supabase)
SUPABASE_URL="https://your-supabase-project-id.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="supabase-service-role-key-placeholder"
SUPABASE_BUCKET_NAME="qr-studio-assets"

# ------------------------------------------------------------------------------
# Stripe Payments Configuration
# ------------------------------------------------------------------------------
STRIPE_API_KEY="sk_test_placeholder"
STRIPE_WEBHOOK_SECRET="whsec_placeholder"
STRIPE_STARTER_PRICE_ID="price_starter_placeholder"
STRIPE_PRO_PRICE_ID="price_pro_placeholder"
STRIPE_ENTERPRISE_PRICE_ID="price_enterprise_placeholder"

# ------------------------------------------------------------------------------
# AI Provider Configuration (Replicate / ComfyUI Server)
# ------------------------------------------------------------------------------
AI_PROVIDER="replicate" # "replicate" or "comfyui"

# Replicate Settings
REPLICATE_API_TOKEN="r8_placeholder"
REPLICATE_MODEL_VERSION="da77098520ec7c7d289dec491d0175b9f9e1e127ccf4c7847b744d9f67a21666" # SDXL + QR ControlNet version

# ComfyUI Settings (if provider is comfyui)
COMFYUI_SERVER_URL="http://localhost:8188"
COMFYUI_WORKFLOW_PATH="./workflow_api.json"

# ------------------------------------------------------------------------------
# Mail Settings (SMTP)
# ------------------------------------------------------------------------------
SMTP_HOST="smtp.mailtrap.io"
SMTP_PORT=2525
SMTP_USER="smtp-username-placeholder"
SMTP_PASS="smtp-password-placeholder"
SMTP_FROM="noreply@3mqrstudio.com"
